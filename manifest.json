{
    "manifest_version": 3,
    "name": "Initia",
    "version": "1.0.0",
    "description": "Startpage minimalista, rápida e focada em privacidade direto no seu navegador.",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "favicon.png",
        "32": "favicon.png",
        "48": "favicon.png",
        "128": "favicon.png"
    },
    "host_permissions": [
        "https://generativelanguage.googleapis.com/*"
    ]
}